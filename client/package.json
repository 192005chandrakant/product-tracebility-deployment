{
  "name": "product-traceability-client",
  "version": "0.1.0",
  "private": true,
  "homepage": "/",
  "dependencies": {
    "@react-three/drei": "^9.88.0",
    "@react-three/fiber": "^8.15.0",
    "ajv": "^8.12.0",
    "ajv-keywords": "^5.1.0",
    "axios": "^1.6.8",
    "compression-webpack-plugin": "^12.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "esbuild": "^0.28.0",
    "ethers": "^6.14.4",
    "firebase": "^11.10.0",
    "framer-motion": "^11.0.20",
    "gsap": "^3.12.5",
    "html5-qrcode": "^2.3.8",
    "jsqr": "^1.4.0",
    "jwt-decode": "^4.0.0",
    "lottie-react": "^2.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.0.1",
    "react-router-dom": "^6.22.3",
    "react-spring": "^9.7.3",
    "react-toastify": "^9.1.3",
    "react-vertical-timeline-component": "^3.6.0",
    "serve": "^14.2.1",
    "tailwindcss": "^3.4.3",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.162.0",
    "web-vitals": "^2.1.4",
    "webpack-bundle-analyzer": "^4.10.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "customize-cra": "^1.0.0",
    "lighthouse": "^12.7.1",
    "postcss": "^8.5.6",
    "react-app-rewired": "^2.2.1",
    "react-scripts": "^5.0.1"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "nth-check": "^2.1.1",
    "resolve-url-loader": "^5.0.0",
    "serialize-javascript": "^7.0.5",
    "underscore": "^1.13.7",
    "webpack-dev-server": "^5.2.3"
  },
  "scripts": {
    "start": "cross-env GENERATE_SOURCEMAP=false DISABLE_ESLINT_PLUGIN=true NODE_OPTIONS=--max-old-space-size=4096 react-app-rewired start",
    "build": "cross-env PUBLIC_URL=/ GENERATE_SOURCEMAP=false CI=false NODE_OPTIONS=--max-old-space-size=4096 react-app-rewired build",
    "build:enhanced": "cross-env PUBLIC_URL=/ GENERATE_SOURCEMAP=false CI=false NODE_OPTIONS=--max-old-space-size=4096 react-app-rewired build",
    "build:prod": "cross-env NODE_ENV=production npm run build:enhanced",
    "build:clean": "npm run clean && npm run build",
    "build:deploy": "node -e \"require('fs').rmSync('build',{recursive:true,force:true})\" && npm run build",
    "build:analyze": "npm run build && npx webpack-bundle-analyzer build/static/js/*.js",
    "clean": "node -e \"const fs=require('fs');['build','node_modules','package-lock.json'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}));\" && npm cache clean --force",
    "clean:install": "npm run clean && npm install",
    "test": "react-app-rewired test",
    "start-server": "cd ../server && npm start",
    "dev": "concurrently \"npm run start-server\" \"npm start\"",
    "preview": "serve -s build -l 3000",
    "compress": "gzip -k -f build/static/js/*.js && gzip -k -f build/static/css/*.css",
    "lighthouse": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
