# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# ═══════════════════════════════════════════════════════════════════════════
# 
# CRITICAL: This file is a template. Create a .env.production file with real
# credentials and keep it SECURE. Never commit actual secrets to git.
#
# Instructions:
# 1. Copy this file to .env.production
# 2. Replace all placeholder values with actual production credentials
# 3. Keep .env.production out of version control (add to .gitignore)
# 4. Use secret management tools in production (Google Secret Manager, AWS Secrets, etc.)
# 5. Rotate all secrets regularly

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════════════
NODE_ENV=production
PORT=8080

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Use production MongoDB instance (Atlas or self-managed)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://[YOUR_USERNAME]:[YOUR_PASSWORD]@[YOUR_CLUSTER].mongodb.net/product-traceability?retryWrites=true&w=majority

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Generate a strong JWT secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=[GENERATE_USING_COMMAND_ABOVE]

# CORS Configuration - Use specific domains only
# DO NOT use CORS_ALLOW_ALL=true in production
CORS_ALLOW_ALL=false
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com,https://www.yourdomain.com

# Trust proxy - enable if behind a reverse proxy (Nginx, Cloud Load Balancer, etc.)
TRUST_PROXY=true

# ═══════════════════════════════════════════════════════════════════════════
# BLOCKCHAIN CONFIGURATION (Ethereum/Polygon)
# ═══════════════════════════════════════════════════════════════════════════
# Smart contract address deployed on Sepolia testnet
CONTRACT_ADDRESS=0x[YOUR_CONTRACT_ADDRESS]

# Private key for blockchain transactions (use secret manager in production)
BLOCKCHAIN_PRIVATE_KEY=[YOUR_PRIVATE_KEY_FROM_SECRET_MANAGER]

# RPC endpoints
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/[YOUR_INFURA_KEY]
MUMBAI_RPC_URL=https://polygon-mumbai.infura.io/v3/[YOUR_INFURA_KEY]
INFURA_API_KEY=[YOUR_INFURA_API_KEY]
INFURA_API_URL=https://sepolia.infura.io/v3/[YOUR_INFURA_KEY]

# ═══════════════════════════════════════════════════════════════════════════
# GEMINI AI CONFIGURATION (Optional but recommended)
# ═══════════════════════════════════════════════════════════════════════════
# Get API key from Google Cloud Console
# Set GEMINI_API_KEY through environment variable or secret manager
GEMINI_API_KEY=[YOUR_GEMINI_API_KEY_FROM_SECRET_MANAGER]
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=15000

# ═══════════════════════════════════════════════════════════════════════════
# CLOUDINARY CONFIGURATION (For image/document storage)
# ═══════════════════════════════════════════════════════════════════════════
STORAGE_TYPE=cloudinary
CLOUDINARY_CLOUD_NAME=[YOUR_CLOUDINARY_CLOUD_NAME]
CLOUDINARY_API_KEY=[YOUR_CLOUDINARY_API_KEY]
CLOUDINARY_API_SECRET=[YOUR_CLOUDINARY_API_SECRET]

# ═══════════════════════════════════════════════════════════════════════════
# ADMIN BOOTSTRAP (Automatic admin account creation on first run)
# ═══════════════════════════════════════════════════════════════════════════
# Set to false after initial setup to prevent unauthorized admin creation
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=admin@yourdomain.com
ADMIN_BOOTSTRAP_PASSWORD=[GENERATE_STRONG_PASSWORD]
ADMIN_BOOTSTRAP_SECRET=[GENERATE_USING_COMMAND: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"]
ADMIN_BOOTSTRAP_ROTATE_PASSWORD=false
ALLOW_ADMIN_REGISTRATION=false

# ═══════════════════════════════════════════════════════════════════════════
# CLIENT APPLICATION URLS
# ═══════════════════════════════════════════════════════════════════════════
CLIENT_APP_URL=https://app.yourdomain.com
REACT_APP_API_URL=https://api.yourdomain.com

# ═══════════════════════════════════════════════════════════════════════════
# FIREBASE CONFIGURATION (For Google OAuth and additional features)
# ═══════════════════════════════════════════════════════════════════════════
REACT_APP_FIREBASE_API_KEY=[YOUR_FIREBASE_API_KEY]
REACT_APP_FIREBASE_AUTH_DOMAIN=[YOUR_PROJECT].firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=[YOUR_PROJECT_ID]
REACT_APP_FIREBASE_STORAGE_BUCKET=[YOUR_PROJECT].firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=[YOUR_SENDER_ID]
REACT_APP_FIREBASE_APP_ID=[YOUR_APP_ID]

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL SERVICES
# ═══════════════════════════════════════════════════════════════════════════
# Google Drive integration (optional)
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_FOLDER_NAME=Product-Uploads

# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION SECURITY CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════
# ✓ Never commit this file with real values to version control
# ✓ Use environment variables or secret managers for all credentials
# ✓ Rotate secrets regularly (at least quarterly)
# ✓ Enable HTTPS/TLS for all connections
# ✓ Use specific CORS origins (never allow-all)
# ✓ Enable rate limiting (enforced in NODE_ENV=production)
# ✓ Keep Node.js and dependencies up to date
# ✓ Monitor logs for suspicious activity
# ✓ Set ADMIN_BOOTSTRAP_ENABLED=false after initial setup
# ✓ Use strong, randomly generated passwords for admin bootstrap
# ✓ Enable SSL/TLS certificates (not self-signed)
# ✓ Set up monitoring and alerting
# ✓ Configure backup and disaster recovery
