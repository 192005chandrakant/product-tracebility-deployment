# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/product-traceability

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-random

# Server Configuration
PORT=8080
NODE_ENV=production

# Cloudinary Configuration (Required for file storage)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Blockchain Configuration (read-only server access)
BLOCKCHAIN_NETWORK=localhost
CONTRACT_ADDRESS=your-contract-address
SEPOLIA_RPC_URL=your-rpc-url

# Gemini AI Configuration (optional, required only for /api/ai endpoints)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=15000
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX=20

# Security Configuration
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000

# File Upload Limits
MAX_FILE_SIZE=10485760
# 10MB in bytes
